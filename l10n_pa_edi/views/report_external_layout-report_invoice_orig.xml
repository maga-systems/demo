<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <template id="add_qr_external_layout_striped" inherit_id="web.external_layout_striped">
        <xpath expr="//div[contains(@t-attf-class, 'header')]" position="inside">
            <t t-if="o._name == 'account.move' and o.l10n_pa_use_cfe">
                <div name="qr_code">
                    <img t-if="o and o.qr_img" t-att-src="image_data_uri(o.qr_img)"
                         style="position:absolute; top:-5px; right:-5px; width: 140px; height: 140px; text-align: center;" alt="QR"/>
                </div>
            </t>
        </xpath>
    </template>

