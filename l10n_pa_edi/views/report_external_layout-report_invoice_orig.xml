    <template id="report_invoice_document" inherit_id="account.report_invoice_document">
        <xpath expr="//div[@id='informations']" position="before">
            <p style="font-size:12px;" t-if="o.l10n_pa_use_cfe" name="l10n_pa_edi_name">
                <strong>Comprobante impreso de Factura Electrónica</strong><br/>
                CUFE : <b><span t-field="o.l10n_pa_dgi_cufe"/></b><br/>
                Consulte en la pagina: https://dgi-fep.mef.gob.pa/Consultas/FacturasPorCUFE<br/>
                Protocolo de autorización : <b><span t-field="o.l10n_pa_auth_protocol_date"/></b>
            </p>
        </xpath>
    </template>

</odoo>
