    <!-- Fijar ancho de tabla principal -->
    <xpath expr="//table[contains(@class,'o_main_table')]" position="attributes">
        <attribute name="style">table-layout: fixed; width: 100%;</attribute>
    </xpath>
    <!-- ===================== -->
    <!-- HEADER DE LA TABLA    -->
    <!-- ===================== -->
    <xpath expr="//table[contains(@class,'o_main_table')]//thead"
           position="replace">
        <thead>
            <tr style="font-size:12px;border:1px solid #ddd;">
                <th style="width: 10%;border:1px solid #ddd;">Cod</th>
                <th style="width: 30%;border:1px solid #ddd;">Descripcion</th>
                <th class="text-end" style="width: 10%;border:1px solid #ddd;">Cantidad</th>
                <th style="width: 10%;border:1px solid #ddd;">Unidad</th>
                <th class="text-end" style="width: 12%;border:1px solid #ddd;">Precio/Unidad</th>
                <th class="text-end" style="width: 13%;border:1px solid #ddd;">Impuestos</th>
                <th class="text-end" style="width: 15%;border:1px solid #ddd;">Total</th>
            </tr>
        </thead>
    </xpath>
    <!-- ========================================================= -->
    <!-- REEMPLAZO CORRECTO DE LAS LÍNEAS (ODOO 18 REAL)            -->
    <!-- ========================================================= -->
    <xpath expr="//table[contains(@class,'o_main_table')]//tbody//t[@t-foreach='lines']"
           position="replace">

        <t t-foreach="lines" t-as="line">
            <tr style="font-size:10px;border:1px solid #ddd;">
                <td style="border:1px solid #ddd;">
                    <span t-field="line.product_id.default_code"/>
                </td>
                <td style="border:1px solid #ddd;">
                    <span t-field="line.name"/>
                </td>
                <td class="text-end" style="border:1px solid #ddd;">
                    <span t-field="line.quantity"/>
                </td>
                <td style="border:1px solid #ddd;" >
                    <span t-field="line.product_uom_id.name"/>
                </td>
                <td class="text-end" style="border:1px solid #ddd;">
                    <span t-field="line.price_unit"/>
                </td>
                <td class="text-end" style="border:1px solid #ddd;">
                    <span t-esc="', '.join(t.name for t in line.tax_ids)"/>
                </td>
                <td class="text-end" style="border:1px solid #ddd;">
                    <span t-field="line.price_total"/>
                </td>
            </tr>
        </t>

    </xpath>
    <xpath expr="//div[@id='total']" position="attributes">
        <attribute name="style">font-size:10px;border:1px solid #ddd;</attribute>
    </xpath>

    <!-- ========================================================= -->
    <!-- MEDIOS DE PAGO Y PLAZOS - ANCHO COMPLETO DESPUÉS DE TABLA -->
    <!-- ========================================================= -->
    <xpath expr="//div[@id='total']/parent::*" position="after">
        <t t-if="o.l10n_pa_use_cfe and o.dgi_payment_ids">
                        <div style="width:100%; font-size:10px; margin-top:15px; page-break-inside:avoid; overflow:hidden;">
                <!-- COLUMNA IZQUIERDA: MEDIOS DE PAGO -->
                <div style="float:left; width:49%; padding-right:5px; box-sizing:border-box;">
                    <h6 style="font-size:11px; font-weight:bold; margin-bottom:5px;">Medios de Pago</h6>
                    <table class="table table-sm table-bordered" style="margin-bottom:0; width:100%;">
                        <thead>
                            <tr style="background-color:#f8f9fa;">
                                <th style="width:40%;">Tipo</th>
                                <th class="text-end" style="width:25%;">B/. Valor</th>
                                <th style="width:35%;">Observación</th>
                            </tr>
                        </thead>
                        <tbody>
                            <tr t-foreach="o.dgi_payment_ids" t-as="pago">
                                <td>
                                    <t t-if="pago.forma_pago_fact == '01'">Crédito</t>
                                    <t t-elif="pago.forma_pago_fact == '02'">Efectivo</t>
                                    <t t-elif="pago.forma_pago_fact == '03'">Tarjeta Crédito</t>
                                    <t t-elif="pago.forma_pago_fact == '04'">Tarjeta Débito</t>
                                    <t t-elif="pago.forma_pago_fact == '08'">Transferencia</t>
                                    <t t-elif="pago.forma_pago_fact == '09'">Cheque</t>
                                    <t t-elif="pago.forma_pago_fact == '99'">
                                        <span t-field="pago.desc_forma_pago"/>
                                    </t>
                                    <t t-else="">Otro</t>
                                </td>
                                <td class="text-end">
                                    <span t-esc="'%.2f' % pago.valor_cuota_pagada"/>
                                </td>
                                <td>
                                    <t t-if="pago.desc_forma_pago">
                                        <span t-field="pago.desc_forma_pago"/>
                                    </t>
                                </td>
                            </tr>
                        </tbody>
                    </table>
                </div>

                <!-- COLUMNA DERECHA: PLAZOS -->
                <div style="float:left; width:49%; padding-left:5px; box-sizing:border-box;">
                    <t t-if="o.plazo_ids or o.dgi_payment_ids.filtered(lambda p: p.forma_pago_fact != '01')">
                        <h6 style="font-size:11px; font-weight:bold; margin-bottom:5px;">Información de Pago a Plazo</h6>
                        <table class="table table-sm table-bordered" style="margin-bottom:0; width:100%;">
                            <thead>
                                <tr style="background-color:#f8f9fa;">
                                    <th style="width:10%;">#</th>
                                    <th style="width:25%;">Fecha</th>
                                    <th class="text-end" style="width:20%;">B/. Valor</th>
                                    <th style="width:45%;">Observación</th>
                                </tr>
                            </thead>
                            <tbody>
                                <t t-set="contador" t-value="1"/>

                                <!-- Pagos inmediatos -->
                                <t t-foreach="o.dgi_payment_ids.filtered(lambda p: p.forma_pago_fact != '01')" t-as="pago">
                                    <tr>
                                        <td><t t-esc="contador"/></td>
                                        <td>
                                            <span t-field="o.invoice_date" t-options='{"format": "dd/MM/yyyy"}'/>
                                        </td>
                                        <td class="text-end">
                                            <span t-esc="'%.2f' % pago.valor_cuota_pagada"/>
                                        </td>
                                        <td style="font-size:9px;">
                                            PAGO INMEDIATO -
                                            <t t-if="pago.forma_pago_fact == '02'">EFECTIVO</t>
                                            <t t-elif="pago.forma_pago_fact == '03'">TARJETA CRÉDITO</t>
                                            <t t-elif="pago.forma_pago_fact == '04'">TARJETA DÉBITO</t>
                                            <t t-elif="pago.forma_pago_fact == '08'">TRANSFERENCIA</t>
                                            <t t-elif="pago.forma_pago_fact == '09'">CHEQUE</t>
                                            <t t-else="">OTRO</t>
                                        </td>
                                    </tr>
                                    <t t-set="contador" t-value="contador + 1"/>
                                </t>

                                <!-- Plazos futuros -->
                                <tr t-foreach="o.plazo_ids" t-as="plazo">
                                    <td><t t-esc="contador + plazo_index"/></td>
                                    <td>
                                        <span t-field="plazo.fecha_vence_cuota" t-options='{"format": "dd/MM/yyyy"}'/>
                                    </td>
                                    <td class="text-end">
                                        <span t-esc="'%.2f' % plazo.valor_cuota"/>
                                    </td>
                                    <td>
                                        <span t-field="plazo.info_pago_cuota"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>
                    </t>
                </div>

                <!-- Clear float -->
                <div style="clear:both;"></div>
            </div>
        </t>
    </xpath>
</template>

</odoo>
