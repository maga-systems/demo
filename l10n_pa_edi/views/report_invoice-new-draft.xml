<!-- Crear un layout custom para facturas de Panamá -->
<template id="external_layout_pa_invoice">
    <t t-call="web.html_container">
        <t t-set="body_classname" t-value="'o_account_reports_page'"/>
        <div class="header">
            <div class="row" style="margin: 0 0 20px 0; min-height: 60px;">
                <div class="col-3">
                    <img t-if="o.company_id.logo" t-att-src="image_data_uri(o.company_id.logo)"
                         style="max-height: 50px; display: block;" alt="Logo"/>
                </div>
                <div class="col-9 text-end" style="font-size:20px;">
                    <strong>DGI - Comprobante Auxiliar de Factura Electrónica</strong><br/>
                </div>
            </div>
        </div>

        <!-- Título del documento CON margin-top -->
        <div style="margin-top: 20px; margin-bottom: 10px;">
            <h2 t-if="layout_document_title">
                <span t-out="layout_document_title"/>
            </h2>
        </div>

        <div class="article o_report_layout_standard">
            <t t-raw="0"/>
        </div>

        <div class="footer o_standard_footer" style="margin-top: 10px;">
            <div class="text-center" style="border-top: 1px solid black; font-size: 9px;">
                <span t-field="o.company_id.name"/>
                <span t-if="o.company_id.country_id"> - <span t-field="o.company_id.country_id.name"/></span>
                <span t-if="o.company_id.email"> - <span t-field="o.company_id.email"/></span>
                <!-- CAMBIO 4: Texto pie de página PAC -->
                <t t-if="o and o.company_id.l10n_pa_ws_environment_id and o.company_id.l10n_pa_ws_environment_id.pac_footer_text">
                    <div><t t-esc="o.company_id.l10n_pa_ws_environment_id.pac_footer_text"/></div>
                </t>
                <div class="text-muted">
                    Page <span class="page"/> of <span class="topage"/>
                </div>
            </div>
        </div>
    </t>
</template>
    <!-- ============================================ -->
    <!-- MODIFICAR el reporte de factura             -->
    <!-- ============================================ -->
<template id="report_invoice_document" inherit_id="account.report_invoice_document">
    <!-- ============================================ -->
    <!-- USAR nuestro layout custom en lugar del estándar -->
    <!-- ============================================ -->
    <xpath expr="//t[@t-call='web.external_layout']" position="attributes">
        <attribute name="t-call">l10n_pa_edi.external_layout_pa_invoice</attribute>
    </xpath>
        <!-- ============================================ -->
        <!-- OCULTAR el bloque de direcciones original    -->
        <!-- ============================================ -->
        <xpath expr="//div[@class='row'][1]" position="replace">
            <div class="row" style="display: none;"/>
        </xpath>

        <!-- ============================================ -->
        <!-- OCULTAR el div informations (fechas, etc)    -->
        <!-- ============================================ -->
        <xpath expr="//div[@id='informations']" position="attributes">
            <attribute name="style">display: none;</attribute>
        </xpath>
        <!-- ============================================ -->
        <!-- BLOQUE EMISOR - Información de la empresa    -->
        <!-- ============================================ -->
        <xpath expr="//div[hasclass('page')]/div[1]" position="before">
            <!-- Para subir o bajar este bloque, ajusta el margin top -->
            <div class="row mb-3" style="border: 1px solid #dddddd; padding: 8px; margin: 80px 0 10px 0;">
                <div class="col-6" style="font-size: 10px;">
                    <strong style="font-size: 12px;">
                        EMISOR
                    </strong><br/>
                    <strong>Nombre:</strong>
                        <span t-field="o.company_id.name"/>
                    <br/>

                    <strong>RUC:</strong>
                    <span t-field="o.company_id.vat"/><br/>

                    <span t-if="o.company_id.street">
                        <strong>Dirección:</strong> <span t-field="o.company_id.street"/><br/>
                    </span>

                    <span t-if="o.company_id.state_id">
                        <span t-field="o.company_id.state_id.name"/>
                    </span>
                    <span t-if="o.company_id.country_id">
                        , <span t-field="o.company_id.country_id.name"/>
                    </span><br/>

                    <span t-if="o.company_id.phone">
                        <strong>Tel:</strong> <span t-field="o.company_id.phone"/><br/>
                    </span>

                    <span t-if="o.company_id.email">
                        <strong>Email:</strong> <span t-field="o.company_id.email"/>
                    </span>
                </div>

                <!-- ============================================ -->
                <!-- BLOQUE RECEPTOR - Información del cliente    -->
                <!-- ============================================ -->
                <div class="col-6" style="font-size: 10px;">
                    <t t-set="tipo_cliente" t-value="o.partner_id.l10n_pa_edi_customer_type"/>

                    <strong style="font-size: 12px;">
                            RECEPTOR
                    </strong><br/>

                    <strong>Nombre:</strong>
                    <span t-field="o.partner_id.name"/><br/>

                    <!-- RUC + DV: Solo para tipos 01 y 03 -->
                    <span t-if="tipo_cliente in ['01', '03']">
                        <strong>RUC:</strong>
                        <span t-field="o.partner_id.vat"/>
                        <span t-if="o.partner_id.l10n_pa_edi_dv">
                            DV <span t-field="o.partner_id.l10n_pa_edi_dv"/>
                        </span><br/>
                    </span>

                    <!-- Identificación Extranjero: Solo para tipo 04 -->
                    <span t-if="tipo_cliente == '04'">
                        <strong>
                            <span t-if="o.partner_id.l10n_pa_edi_tipo_identificacion == '01'">Pasaporte:</span>
                            <span t-elif="o.partner_id.l10n_pa_edi_tipo_identificacion == '02'">NIT:</span>
                            <span t-else="">Identificación:</span>
                        </strong>
                        <span t-field="o.partner_id.l10n_pa_edi_nro_identificacion_extranjero"/><br/>

                        <strong>País:</strong>
                        <span t-field="o.partner_id.l10n_pa_edi_paisextranjero.name"/><br/>
                    </span>

                    <!-- Dirección: Para tipos 01, 02 y 03 -->
                    <strong>Dirección:</strong>
                    <span t-if="tipo_cliente in ['01', '02', '03']">
                        <span t-if="o.partner_id.street">
                            <span t-field="o.partner_id.street"/>,
                        </span>

                        <span t-if="o.partner_id.street2">
                            <span t-field="o.partner_id.street2"/>
                        </span>
                        <br/>
                        <!--
                        <span t-if="o.partner_id.district_id">
                            <span t-field="o.partner_id.district_id.name"/>,
                        </span>
                        <span t-if="o.partner_id.state_id">
                            <span t-field="o.partner_id.state_id.name"/>
                        </span><br/>
                        <span t-if="o.partner_id.l10n_pa_edi_codigoubicacion">
                            <strong>Cód. Ubicación:</strong>
                            <span t-field="o.partner_id.l10n_pa_edi_codigoubicacion"/><br/>
                        </span>
                        -->
                    </span>

                    <span t-if="o.partner_id.phone">
                        <strong>Tel:</strong> <span t-field="o.partner_id.phone"/><br/>
                    </span>

                    <span t-if="o.partner_id.email">
                        <strong>Email:</strong> <span t-field="o.partner_id.email"/>
                    </span>
                    <br/>
                    <!-- Tipo de Contribuyente -->
                   <strong style="font-size: 10px;">Tipo:</strong>
                        <span t-field="o.partner_id.l10n_pa_edi_customer_type"/>
                    <!--
                        <span t-if="tipo_cliente == '01'">CONTRIBUYENTE</span>
                        <span t-elif="tipo_cliente == '02'">CONSUMIDOR FINAL</span>
                        <span t-elif="tipo_cliente == '03'">ENTIDAD GUBERNAMENTAL</span>
                        <span t-elif="tipo_cliente == '04'">CLIENTE EXTRANJERO</span>
                        <span t-else="">CLIENTE</span>
                    -->
                    <!-- Natural o Juridico -->
                    <span t-if="tipo_cliente in ['01', '02', '03'] and o.partner_id.l10n_pa_edi_tipo_contribuyente">
                        <strong>/</strong>
                        <span t-if="o.partner_id.l10n_pa_edi_tipo_contribuyente == '1'">Natural</span>
                        <span t-else="">Jurídico</span><br/>
                    </span>
                </div>
            </div>
        </xpath>

