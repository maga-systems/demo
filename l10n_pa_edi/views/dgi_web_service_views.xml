<odoo>
    <data>
        <!-- Tree View -->
        <record id="view_dgi_web_service_tree" model="ir.ui.view">
            <field name="name">dgi.web.service.tree</field>
            <field name="model">dgi.web.service</field>
            <field name="arch" type="xml">
                <list>
                    <field name="environment"/>
                    <field name="company_id"/>
                </list>
            </field>
        </record>

        <record id="view_dgi_web_service_form" model="ir.ui.view">
            <field name="name">dgi.web.service.form</field>
            <field name="model">dgi.web.service</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <group>
                            <field name="environment"/>
                            <field name="ws_wsdl_url"/>
                            <field name="ws_user_fname" />
                            <field name="ws_token_fname" password="True"/>
                            <field name="company_id"/>
                            <field name="pac_footer_text"
                                   placeholder="Ej: Documento validado por The Factory HKA Corp. con RUC 155596713-2-2015"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>


        <record id="action_dgi_web_service" model="ir.actions.act_window">
            <field name="name">DGI Web Services</field>
            <field name="res_model">dgi.web.service</field>
            <field name="view_mode">list,form</field>
            <field name="view_id" ref="view_dgi_web_service_tree" />
        </record>

    </data>
</odoo>
