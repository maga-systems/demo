<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>

        <!-- ============================= -->
        <!-- FORM VIEW INHERIT PRINCIPAL -->
        <!-- ============================= -->
    <record id="view_l10n_pa_edi_invoice_form_inherit" model="ir.ui.view">
        <field name="name">l10n_pa_edi.invoice.form.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <!-- Stat button Logs FEL -->
            <xpath expr="//div[@name='button_box']" position="inside">
                <button type="object"
                        name="action_view_fel_logs"
                        class="oe_stat_button"
                        icon="fa-list-alt"
                        invisible="l10n_pa_use_cfe == False">
                    <field name="log_fel_count" widget="statinfo" string="Logs FEL"/>
                </button>
            </xpath>

            <!-- Botón FE -->
            <xpath expr="//button[@name='action_post'][1]" position="after">
                <button type="object"
                        string="Crear Factura Electrónica"
                        name="action_certificate"
                        invisible="state in ('draft') or l10n_pa_edi_status == 'process'"/>
            </xpath>

            <!-- Ocultar volver a borrador -->
            <xpath expr="//button[@name='button_draft']" position="attributes">
                <attribute name="groups">base.group_no_one</attribute>
            </xpath>

            <!-- Campos DGI -->
            <xpath expr="//sheet/group//group[last()]" position="inside">
                <field name="l10n_pa_use_cfe" invisible="1"/>

                <label for="l10n_pa_no_doc_factura" invisible="state in ('draft')"/>
                <div class="o_row"  invisible="state in ('draft')">
                    <field name="l10n_pa_no_doc_factura" groups="base.group_no_one"/>
                    <field name="l10n_pa_no_doc_factura" readonly="1" groups="!base.group_no_one"/>
                    <button name="l10n_pa_update_files"
                            string="UPDATE Files"
                            type="object"
                            class="oe_highlight"
                            groups="base.group_no_one"/>
                </div>

                <label for="l10n_pa_edi_status" invisible="l10n_pa_use_cfe == False" />
                <div class="o_row" invisible="l10n_pa_use_cfe == False">
                    <field name="l10n_pa_edi_status"
                           widget="badge"
                           decoration-success="l10n_pa_edi_status == 'process'"
                           decoration-muted="l10n_pa_edi_status in ['none','not_found']"
                           decoration-danger="l10n_pa_edi_status == 'undefined'"/>
                </div>
            </xpath>

            <!-- CUFE / QR -->
            <xpath expr="//sheet/group//group[last()]" position="after">
                <group colspan="4">
                    <!-- Electronic invoice -->
                    <field name="l10n_pa_dgi_cufe"
                           invisible="l10n_pa_use_cfe == False or l10n_pa_dgi_cufe == False"/>
                    <field name='l10n_pa_dgi_qr_code' invisible="1"/>
                </group>
            </xpath>

            <!-- QR visual -->
            <xpath expr="//h1//field[@name='name']" position="after">
                <link rel="stylesheet"
                      type="text/css"
                      href="/l10n_pa_edi/static/src/css/style.css"/>
                <div name="qr_code" class="topcorner">
                    <field name="qr_img"
                           widget="image"
                           invisible="l10n_pa_use_cfe == False or qr_img == False"/>
                </div>
            </xpath>

            <!-- Tabs -->
            <xpath expr="//page[@id='other_tab']" position="after">

                <page string="Referencias Cruzadas de Documentos"
                      name="cross_reference_docs"
                      invisible="l10n_pa_use_cfe == False or move_type not in ['in_invoice', 'in_refund', 'out_invoice', 'out_refund']">
                    <field name="reference_ids" mode="list">
                        <form>
                            <group>
                                <field name="origin_doc_number" required="True"/>
                                <field name="reference_doc_code" />
                                <field name="reason"/>
                                <field name="date"/>
                                <field name="move_id" invisible="1"/>
                                <field name="source_move_id" invisible="1"/>
                            </group>
                        </form>

                        <list>
                            <field name="origin_doc_number" required="True"/>
                            <field name="reference_doc_code"/>
                            <field name="reason"/>
                            <field name="date"/>
                            <field name="move_id" invisible="1"/>
                            <field name="source_move_id"/>
                        </list>

                    </field>
                </page>

                <page string="SFEP Panamá"
                      name="l10_pa_edi"
                      invisible="l10n_pa_use_cfe == False or move_type not in ['in_invoice', 'in_refund', 'out_invoice', 'out_refund']">

                    <group string="Documento Fiscal">
                        <field name="l10n_pa_edi_tipo_documento_desc"
                               string="Tipo Documento"
                               readonly="1"
                               help="Tipo de documento enviado a la DGI. Se determina automáticamente según el tipo de factura."/>
                        <field name="l10n_pa_no_doc_factura"
                               string="Número Documento Fiscal"
                               readonly="1"
                               help="Número secuencial asignado al momento del envío al PAC. Máx. 10 dígitos."/>
                        <field name="l10n_pa_dgi_cufe"
                               readonly="1"
                               help="Código Único de Factura Electrónica asignado por la DGI. 66 caracteres."/>
                        <field name="l10n_pa_edi_post_time"
                               string="Hora de Envío"
                               readonly="1"
                               help="Fecha y hora en que se procesó el documento. Zona horaria UTC-5 Panamá."/>
                    </group>

                    <group string="Autorización DGI">
                        <field name="l10n_pa_auth_protocol"
                               readonly="1"
                               help="Número de protocolo asignado por la DGI al autorizar el documento."/>
                        <field name="l10n_pa_auth_dgi_reception_date"
                               readonly="1"
                               help="Fecha en que la DGI recibió y procesó el documento electrónico."/>
                        <field name="l10n_pa_auth_protocol_date"
                               readonly="1"/>
                        <field name="l10n_pa_edi_status"
                               string="Estado DGI"
                               readonly="1"
                               widget="badge"
                               decoration-success="l10n_pa_edi_status == 'process'"
                               decoration-danger="l10n_pa_edi_status == 'undefined'"
                               decoration-muted="l10n_pa_edi_status in ['none', 'not_found', 'cancelled']"
                               help="Estado del documento dentro del sistema DGI."/>
                    </group>

                </page>

                <page string="Detalle FEL"
                      name="l10n_pa_fel_detail"
                      invisible="l10n_pa_use_cfe == False or move_type not in ['in_invoice', 'in_refund', 'out_invoice', 'out_refund']">
                    <group string="XML Enviado al PAC">
                        <field name="l10n_pa_last_xml_send"
                               nolabel="1"
                               widget="code"
                               readonly="1"
                               placeholder="Sin datos — la factura aún no ha sido enviada al PAC."/>
                    </group>
                    <group string="Respuesta Completa del PAC">
                        <field name="l10n_pa_last_response"
                               nolabel="1"
                               widget="code"
                               readonly="1"
                               placeholder="Sin datos — la factura aún no ha sido enviada al PAC."/>
                    </group>
                </page>
            </xpath>
            
        </field>
    </record>

    <record id="view_move_form_dgi_payment_inline" model="ir.ui.view">
        <field name="name">account.move.form.dgi.payment.inline</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">

            <xpath expr="//sheet" position="inside">

                <!-- ============================= -->
                <!-- FORMAS DE PAGO DGI -->
                <!-- ============================= -->
                <!-- has_credit_payment es para guardar cuando si es credito -->
                <field name="has_credit_payment" invisible="1"/>

                <group string="Formas de Pago DGI">
                    <field name="dgi_payment_ids">
                        <list editable="bottom">
                            <field name="currency_id" column_invisible="1"/>
                            <field name="forma_pago_fact"/>
                            <field name="desc_forma_pago"/>
                            <field name="valor_cuota_pagada" widget="float"
                                  digits="[16,2]" sum="Total"/>
                        </list>
                    </field>

                </group>

                <!-- ============================= -->
                <!-- PLAZOS DE CRÉDITO (POPUP) -->
                <!-- ============================= -->
                <group
                    string="Plazos de Pago (Requerido para Forma de Pago = Credito)"
                    invisible="not has_credit_payment">

                    <field name="plazo_ids">
                        <list editable="bottom">
                            <field name="currency_id" column_invisible="1"/>
                            <field name="fecha_vence_cuota"/>
                            <field name="valor_cuota" widget="float"
                                  digits="[16,2]" sum="Total"/>
                            <field name="info_pago_cuota" placeholder="Mín. 15 caracteres si se indica" help="Opcional. Si se informa, debe tener entre 15 y 1000 caracteres (norma DGI)."/>
                        </list>
                    </field>

                </group>

            </xpath>
        </field>
    </record>



    <!-- Vista tipo LIST -->
    <record id="view_move_tree_l10n_pa_edi" model="ir.ui.view">
        <field name="name">account.move.tree.l10n_pa_edi</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='invoice_date']" position="after">
                <field name="l10n_pa_dgi_payment_code"/>
            </xpath>
        </field>
    </record>


    <!-- Action para descargar pdf usando la funcion _dowload_l10n_pa_edit_pdf-->
    <record id="view_account_move_filter_ih" model="ir.ui.view">
        <field name="name">account.move.filter.ih</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter" />
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field string="Ref. PAC" name="l10n_pa_no_doc_factura" />
            </field>
        </field>
    </record>

    <record id="tree_decorator_dgi_inherit_module_name" model="ir.ui.view">
        <field name="name">account.move.decorator.view.form.inherit</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_out_invoice_tree"/>
        <field name="arch" type="xml">
            <xpath expr="//list" position="inside">
                <field name="l10n_pa_edi_status" widget="badge"/>
            </xpath>
            <xpath expr="//field[@name='l10n_pa_edi_status']" position="attributes">
                <attribute name="decoration-success">l10n_pa_edi_status == 'process'</attribute>
            </xpath>
            <xpath expr="//field[@name='l10n_pa_edi_status']" position="attributes">
                <attribute name="decoration-muted">l10n_pa_edi_status in ['none', 'not_found', 'cancelled']</attribute>
            </xpath>
            <xpath expr="//field[@name='l10n_pa_edi_status']" position="attributes">
                <attribute name="decoration-danger">l10n_pa_edi_status == 'undefined'</attribute>
            </xpath>
        </field>
    </record>

    <record id="view_account_move_filter_ih" model="ir.ui.view">
        <field name="name">account.move.filter.ih</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_account_invoice_filter" />
        <field name="arch" type="xml">
            <field name="partner_id" position="after">
                <field string="Ref. PAC" name="l10n_pa_no_doc_factura" />
                <filter name="l10n_pa_edi_status"
                        string="Fact. no certificadas"
                        domain="[('l10n_pa_edi_status', '=', 'undefined')]"/>
            </field>
        </field>
    </record>

     <!-- =========================
             SERVER ACTION
        ========================== -->
    <record id="account_move_action_server" model="ir.actions.server">
        <field name="name">Crear FEs en Lote</field>
        <field name="model_id" ref="model_account_move"/>
        <field name="binding_model_id" ref="model_account_move"/>
        <field name="binding_view_types">list</field>
        <field name="state">code</field>
        <field name="code">
            <![CDATA[
        action = records.certificate_records()
            ]]>
        </field>
    </record>
    </data>
</odoo>